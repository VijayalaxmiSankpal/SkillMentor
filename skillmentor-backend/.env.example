# ============================================
# SERVER CONFIGURATION
# ============================================
NODE_ENV=development
PORT=5000
API_VERSION=v1

# ============================================
# DATABASE
# ============================================
MONGODB_URI=mongodb://127.0.0.1:27017/skillmentor

# ============================================
# CORS
# ============================================
CLIENT_URL=http://localhost:5173

# ============================================
# JWT
# ============================================
JWT_ACCESS_SECRET=your_access_secret_min_32_chars_long_random
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_SECRET=your_refresh_secret_min_32_chars_long_random
JWT_REFRESH_EXPIRY=7d

# ============================================
# EMAIL
# ============================================
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USER=your_mailtrap_user
MAIL_PASS=your_mailtrap_pass
MAIL_FROM_NAME=SkillMentor AI
MAIL_FROM_EMAIL=no-reply@skillmentor.ai

# ============================================
# AI
# ============================================
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100